<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zenith PM - Enterprise Project Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: 'Inter', sans-serif; background: #F4F6F9; color: #1A1A2E; }
            .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
            /* Navbar */
            .navbar { background: #0A1628; padding: 16px 0; position: sticky; top: 0; z-index: 1000; }
            .navbar .container { display: flex; justify-content: space-between; align-items: center; }
            .logo { color: white; font-size: 24px; font-weight: 700; }
            .logo span { color: #2A6DF4; }
            .nav-links { display: flex; gap: 30px; align-items: center; }
            .nav-links a { color: #C8D0DC; text-decoration: none; font-size: 15px; font-weight: 500; }
            .nav-links a:hover { color: white; }
            .btn-nav { background: #2A6DF4; color: white !important; padding: 8px 20px; border-radius: 6px; }
            .btn-nav:hover { background: #1E5AD4; }

            /* Footer */
            .footer { background: #0A1628; color: #8896A6; text-align: center; padding: 30px 0; margin-top: 40px; }
            .footer a { color: #2A6DF4; text-decoration: none; }

            /* Utility */
            .text-center { text-align: center; }
            .mt-20 { margin-top: 20px; }
            .mb-20 { margin-bottom: 20px; }

            /* Responsive */
            @@media (max-width: 768px) {
                .nav-links { display: none; }
                .nav-links.open { display: flex; flex-direction: column; gap: 15px; }
            }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">ZENITH <span>PM</span></a>
            <div class="nav-links" id="navLinks">
                <a href="/">Home</a>
                <a href="/Home/Features">Features</a>
                <a href="/Home/About">About</a>
                <a href="/Home/Contact">Contact</a>
                <a href="/Auth/Login" class="btn-nav">Login</a>
                <a href="/Auth/Register" class="btn-nav" style="background:#1E5AD4;">Get Started</a>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Zenith PM. All rights reserved.</p>
            <p style="margin-top:10px; font-size:14px;">
                <a href="#">Privacy</a> | <a href="#">Terms</a> | <a href="#">Support</a>
            </p>
        </div>
    </footer>

    <script>
            // Mobile menu toggle (optional)
            console.log('Zenith PM loaded');
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>