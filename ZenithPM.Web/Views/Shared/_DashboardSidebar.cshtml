@using System.Security.Claims
@{
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value;
}

<div class="sidebar">
    <div class="sidebar-brand">
        <h3>ZENITH <span>PM</span></h3>
        <small>Enterprise Suite</small>
    </div>
    <ul class="sidebar-nav">
        <!-- Dashboard -->
        <li class="nav-item">
            <a href="/Dashboard/@userRole" class="nav-link active">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
            </a>
        </li>

        <!-- SuperAdmin Only -->
        @if (userRole == "SuperAdmin")
        {
            <li class="nav-item">
                <a href="/Admin/Index" class="nav-link">
                    <i class="fas fa-shield-alt"></i> <span>Admin Panel</span>
                </a>
            </li>
        }

        <!-- Admin & SuperAdmin -->
        @if (userRole == "Admin" || userRole == "SuperAdmin")
        {
            <li class="nav-item">
                <a href="/Department/Index" class="nav-link">
                    <i class="fas fa-building"></i> <span>Departments</span>
                </a>
            </li>
        }

        <!-- Manager & Above -->
        @if (userRole == "Manager" || userRole == "Admin" || userRole == "SuperAdmin")
        {
            <li class="nav-item">
                <a href="/Project/Index" class="nav-link">
                    <i class="fas fa-project-diagram"></i> <span>Projects</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/Task/Index" class="nav-link">
                    <i class="fas fa-tasks"></i> <span>Tasks</span>
                </a>
            </li>
        }

        <!-- Employee Only -->
        @if (userRole == "Employee")
        {
            <li class="nav-item">
                <a href="/Task/MyTasks" class="nav-link">
                    <i class="fas fa-list-ul"></i> <span>My Tasks</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/Attendance/Mark" class="nav-link">
                    <i class="fas fa-clock"></i> <span>Attendance</span>
                </a>
            </li>
        }

        <!-- Divider -->
        <li class="nav-divider"></li>

        <!-- Logout -->
        <li class="nav-item">
            <a href="/Auth/Logout" class="nav-link logout">
                <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
            </a>
        </li>
    </ul>
</div>

<style>
    .sidebar {
        width: 260px;
        height: 100vh;
        background: #0B1A33;
        color: white;
        position: fixed;
        top: 0;
        left: 0;
        overflow-y: auto;
        padding: 0;
        z-index: 1050;
        border-right: 1px solid rgba(255,255,255,0.06);
        transition: all 0.3s ease;
    }

    .sidebar-brand {
        padding: 24px 20px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }

    .sidebar-brand h3 {
        color: white;
        font-size: 22px;
        font-weight: 800;
        letter-spacing: -0.5px;
        margin: 0;
    }

    .sidebar-brand h3 span {
        color: #3B82F6;
    }

    .sidebar-brand small {
        color: rgba(255,255,255,0.3);
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: block;
        margin-top: 4px;
    }

    .sidebar-nav {
        list-style: none;
        padding: 16px 12px;
        margin: 0;
    }

    .sidebar-nav .nav-item {
        margin-bottom: 2px;
    }

    .sidebar-nav .nav-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 16px;
        border-radius: 10px;
        color: rgba(255,255,255,0.55);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .sidebar-nav .nav-link i {
        width: 20px;
        font-size: 16px;
        text-align: center;
        flex-shrink: 0;
    }

    .sidebar-nav .nav-link:hover {
        background: rgba(255,255,255,0.07);
        color: white;
    }

    .sidebar-nav .nav-link.active {
        background: rgba(59, 130, 246, 0.15);
        color: white;
        box-shadow: inset 3px 0 0 #3B82F6;
    }

    .sidebar-nav .nav-divider {
        height: 1px;
        background: rgba(255,255,255,0.06);
        margin: 12px 16px;
    }

    .sidebar-nav .nav-link.logout {
        color: #EF4444;
        margin-top: 4px;
    }

    .sidebar-nav .nav-link.logout:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
    }

    /* Scrollbar */
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 10px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }

    /* Responsive */
    @@media (max-width: 768px) {
        .sidebar { width: 64px; }
        .sidebar-brand small { display: none; }
        .sidebar-nav .nav-link span { display: none; }
        .sidebar-nav .nav-link { justify-content: center; padding: 12px; }
        .sidebar-nav .nav-link i { margin: 0; font-size: 18px; }
        .sidebar-brand h3 { font-size: 16px; }
    }
</style>