<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zenith PM - @ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0A1628 0%, #1A2A4A 50%, #0A1628 100%);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-y: auto;
            position: relative;
        }
        body::before {
            content: '';
            position: fixed;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(42,109,244,0.08) 0%, transparent 70%);
            top: -200px;
            right: -200px;
            border-radius: 50%;
            animation: float 8s ease-in-out infinite;
            z-index: 0;
        }
        body::after {
            content: '';
            position: fixed;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(42,109,244,0.05) 0%, transparent 70%);
            bottom: -100px;
            left: -100px;
            border-radius: 50%;
            animation: float 10s ease-in-out infinite reverse;
            z-index: 0;
        }
        @@keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, -30px) scale(1.1); }
        }
        .auth-container {
            width: 100%;
            max-width: 480px;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }
        .auth-card {
            background: rgba(10, 22, 40, 0.85);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-radius: 24px;
            padding: 40px 32px;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            width: 100%;
            transition: all 0.3s ease;
        }
        .auth-card:hover {
            box-shadow: 0 30px 80px rgba(42,109,244,0.15);
            border-color: rgba(42,109,244,0.2);
        }
        .auth-logo {
            text-align: center;
            margin-bottom: 28px;
        }
        .auth-logo h1 {
            font-size: 30px;
            font-weight: 800;
            color: white;
            letter-spacing: -0.5px;
        }
        .auth-logo h1 span {
            color: #2A6DF4;
            text-shadow: 0 0 40px rgba(42,109,244,0.3);
        }
        .auth-logo p {
            color: rgba(255,255,255,0.5);
            font-size: 13px;
            margin-top: 4px;
            font-weight: 300;
            letter-spacing: 0.5px;
        }
        .form-label {
            font-weight: 500;
            font-size: 12px;
            color: rgba(255,255,255,0.7);
            letter-spacing: 0.3px;
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .form-control {
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid rgba(255,255,255,0.15);
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: white !important;
            background: rgba(255,255,255,0.1) !important;
            transition: all 0.3s ease;
            width: 100%;
            height: 48px;
        }
        .form-control:focus {
            border-color: #2A6DF4;
            box-shadow: 0 0 0 4px rgba(42,109,244,0.15);
            background: rgba(255,255,255,0.15) !important;
        }
        .form-control::placeholder {
            color: rgba(255,255,255,0.45) !important;
            font-weight: 300;
            opacity: 1;
        }
        .input-group {
            position: relative;
        }
        .input-group .form-control {
            padding-right: 50px;
        }
        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            padding: 6px;
            z-index: 10;
            line-height: 1;
            border-radius: 50%;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .toggle-password i {
            color: #2A6DF4 !important;
        }
        .toggle-password:hover {
            background: rgba(42,109,244,0.15);
        }
        .btn-primary {
            background: linear-gradient(135deg, #2A6DF4, #1E5AD4);
            border: none;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
            font-family: 'Inter', sans-serif;
            color: white;
            font-size: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
            letter-spacing: 0.3px;
            height: 48px;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(42,109,244,0.35);
        }
        .btn-primary:active {
            transform: translateY(0);
        }
        .auth-link {
            color: #2A6DF4;
            text-decoration: none;
            font-weight: 500;
            font-size: 13px;
            transition: color 0.3s;
        }
        .auth-link:hover {
            color: #5A8DF4;
            text-decoration: underline;
        }
        .text-muted {
            color: rgba(255,255,255,0.4) !important;
            font-size: 13px;
        }
        .form-check-label {
            color: rgba(255,255,255,0.6);
            font-size: 13px;
        }
        .form-check-input {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.15);
        }
        .form-check-input:checked {
            background-color: #2A6DF4;
            border-color: #2A6DF4;
        }
        .alert {
            border-radius: 12px;
            font-size: 13px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            color: white;
            padding: 10px 14px;
        }
        .alert-success { border-color: rgba(46,213,115,0.3); color: #2ED573; }
        .alert-danger { border-color: rgba(255,71,87,0.3); color: #FF4757; }
        .text-danger { color: #FF4757 !important; }
        .divider {
            text-align: center;
            margin: 16px 0;
            position: relative;
        }
        .divider::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            width: 100%;
            height: 1px;
            background: rgba(255,255,255,0.06);
        }
        .divider span {
            background: rgba(10, 22, 40, 0.85);
            padding: 0 14px;
            color: rgba(255,255,255,0.3);
            font-size: 11px;
            position: relative;
        }
        .row {
            display: flex;
            flex-wrap: wrap;
            margin: 0 -6px;
        }
        .col-6 {
            flex: 0 0 50%;
            max-width: 50%;
            padding: 0 6px;
        }
        .mb-3 { margin-bottom: 14px; }
        .mt-3 { margin-top: 14px; }
        .mt-2 { margin-top: 10px; }

        @@media (max-width: 480px) {
            body { padding: 20px 10px; }
            .auth-card { padding: 28px 20px; }
            .auth-logo h1 { font-size: 24px; }
            .col-6 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            .form-control { height: 44px; font-size: 13px; }
            .btn-primary { height: 44px; font-size: 14px; }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <h1>ZENITH <span>PM</span></h1>
                <p>Enterprise Project Management</p>
            </div>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success">@ViewBag.Message</div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(btn) {
            const input = btn.parentElement.querySelector('.form-control');
            if (input) {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                const icon = btn.querySelector('i');
                icon.classList.toggle('fa-eye');
                icon.classList.toggle('fa-eye-slash');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>