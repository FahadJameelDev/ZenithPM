@model ZenithPM.Web.Models.ViewModels.UserManagementViewModel

@{
    ViewData["Title"] = "Edit User Role";
    Layout = "_Layout";
}

<h2>Edit User Role</h2>
<h4>User: @ViewBag.UserName</h4>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@ViewBag.UserId" />

    <div class="mb-3">
        <label class="form-label">Role</label>
        <select asp-for="SelectedRoleId" class="form-control">
            @foreach (var role in Model.Roles)
            {
                <option value="@role.Id">@role.Name</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
</form>